# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environments
.venv/
venv/
env/

# Oxford-IIIT Pet dataset and large archives
data/OxfordPets/images/
data/OxfordPets/annotations/
data/OxfordPets/*.tar.gz
data/OxfordPets/*.tgz
data/OxfordPets/*.zip

# Training and generated experiment artifacts
outputs/checkpoints/
outputs/figures/
outputs/reports/
*.pt
*.pth
*.ckpt

# Keep output directories in the tree via .gitkeep if needed
!outputs/checkpoints/.gitkeep
!outputs/figures/.gitkeep
!outputs/reports/.gitkeep
